{
  "$schema": "./dotfiles-map.schema.json",
  "version": 1,
  "mappings": [
    {
      "name": "fish",
      "source": "fish",
      "target": "~/.config/fish",
      "mode": "link_children",
      "exclude": [
        ".DS_Store",
        ".gitignore",
        "fish_variables*",
        "fishd.tmp*"
      ]
    },
    {
      "name": "nvim",
      "source": "nvim",
      "target": "~/.config/nvim",
      "mode": "symlink"
    },
    {
      "name": "ideavim",
      "source": "nvim/ideavimrc",
      "target": "~/.ideavimrc",
      "mode": "symlink"
    },
    {
      "name": "kitty",
      "source": "kitty.conf",
      "target": "~/.config/kitty/kitty.conf",
      "mode": "symlink"
    },
    {
      "name": "kitty-macos",
      "source": "kitty-macos.conf",
      "target": "~/.config/kitty/kitty-macos.conf",
      "mode": "symlink",
      "platforms": [
        "macos"
      ]
    },
    {
      "name": "git",
      "source": "gitconfig",
      "target": "~/.gitconfig",
      "mode": "symlink"
    },
    {
      "name": "tmux",
      "source": "tmux/tmux.conf",
      "target": "~/.tmux.conf",
      "mode": "symlink"
    },
    {
      "name": "tmux-local",
      "source": "tmux/tmux.conf.local",
      "target": "~/.tmux.conf.local",
      "mode": "symlink"
    },
    {
      "name": "opencode",
      "source": "opencode",
      "target": "~/.config/opencode",
      "mode": "link_children",
      "exclude": [
        ".env",
        "Dockerfile",
        "docker-compose.yml",
        "entrypoint.sh",
        "opencode.plist",
        "opencode.service",
        "server.sh"
      ]
    },
    {
      "name": "niri",
      "source": "niri/config.kdl",
      "target": "~/.config/niri/config.kdl",
      "mode": "symlink",
      "platforms": [
        "linux"
      ]
    },
    {
      "name": "ironbar",
      "source": "ironbar",
      "target": "~/.config/ironbar",
      "mode": "symlink",
      "platforms": [
        "linux"
      ]
    },
    {
      "name": "keyd",
      "source": "keyd/default.conf",
      "target": "/etc/keyd/default.conf",
      "mode": "symlink",
      "platforms": [
        "linux"
      ]
    }
  ]
}
