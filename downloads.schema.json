{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./downloads.schema.json",
  "title": "Downloads Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "tools"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    }
  },
  "$defs": {
    "tool": {
      "oneOf": [
        {
          "$ref": "#/$defs/archiveTool"
        },
        {
          "$ref": "#/$defs/gitTool"
        }
      ]
    },
    "archiveTool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "targets"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.\\.?$)[^/\\\\]+$"
        },
        "type": {
          "type": "string",
          "const": "archive"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.\\.?$)[^/\\\\]+$"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/target"
          }
        }
      }
    },
    "gitTool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "url",
        "ref",
        "target"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "const": "git"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[^/]+(?:/[^/]+)*$"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "platform",
        "arch",
        "url",
        "sha256",
        "archive",
        "executable"
      ],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.\\.?$)[^/\\\\]+$"
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9A-Fa-f]{64}$"
        },
        "archive": {
          "type": "string",
          "enum": [
            "tar.gz",
            "zip"
          ]
        },
        "executable": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)[^/]+(?:/[^/]+)*$"
        }
      }
    }
  }
}
