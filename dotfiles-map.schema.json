{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./dotfiles-map.schema.json",
  "title": "Dotfiles Mapping Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "mappings"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "mappings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mapping"
      }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "symlink",
            "link_children"
          ]
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional": {
          "type": "boolean"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "linux",
              "macos"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
