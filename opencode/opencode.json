{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "snapshot": false,
  "shell": "bash",
  "plugin": [
    // "opencode-gemini-auth@latest",
    // "opencode-openai-codex-auth@latest",
    // "oh-my-opencode@latest",
    // "opencode-antigravity-auth@latest"
    // "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "tmux": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tmux-mcp",
        "--shell-type=fish"
      ],
      "enabled": true
    }
  },
  "permission": {
    "external_directory": {
      "/tmp": "allow",
      "/tmp/**": "allow",
      "/private/tmp": "allow",
      "/private/tmp/**": "allow",
      "~/dotfiles/": "allow",
      "~/dotfiles/**": "allow",
    }
  },
  "agent": {
    "explore": {
      "permission": {
        "codebase-memory-mcp_get*": "allow",
        "codebase-memory-mcp_search*": "allow",
        "codebase-memory-mcp_list*": "allow",
        "codebase-memory-mcp_query_graph": "allow",
        "codebase-memory-mcp_trace*": "allow",
        "codebase-memory-mcp_detect*": "allow",
        "codebase-memory-mcp_*status": "allow"
      }
    },
    "compaction": {
      "model": "openai/gpt-5.4-fast"
    }
  },
  "provider": {}
}
