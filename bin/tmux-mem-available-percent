#!/usr/bin/env bash
set -euo pipefail

meminfo_path=${TMUX_MEMINFO_PATH:-/proc/meminfo}

awk '
  /MemTotal/ { total = $2 }
  /MemAvailable/ { available = $2 }
  END {
    if (total > 0) {
      used = total - available
      percent = used / total * 100
      if (percent >= 90) {
        printf "#[fg=#d70000]%02.0f%%#[fg=#8a8a8a]", percent
      } else {
        printf "%02.0f%%", percent
      }
    }
  }
' "$meminfo_path"
