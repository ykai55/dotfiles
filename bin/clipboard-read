#!/usr/bin/env swift

import AppKit
import Foundation

struct ClipboardFile: Codable {
    let path: String
    let name: String
    let isDirectory: Bool
    let byteSize: Int64?
}

struct ClipboardItem: Codable {
    let kind: String
    let text: String?
    let length: Int?
    let files: [ClipboardFile]?
    let urls: [String]?
    let path: String?
    let format: String?
    let sourceType: String?
    let byteSize: Int?
}

struct ClipboardDump: Codable {
    let platform: String
    let changeCount: Int
    let empty: Bool
    let pasteboardTypes: [String]
    let outputDir: String?
    let items: [ClipboardItem]
}

let defaultOutputDirectory = URL(fileURLWithPath: "/tmp/opencode-clipboard", isDirectory: true)

func fail(_ message: String) -> Never {
    fputs("clipboard-read: \(message)\n", stderr)
    exit(1)
}

func printUsage() {
    let usage = """
    Usage: clipboard-read [--output-dir DIR] [--pretty]

    Read the current macOS system clipboard and emit JSON.

    Options:
      --output-dir DIR  Directory used when exporting clipboard images
      --pretty          Pretty-print JSON output
      -h, --help        Show this help message
    """

    print(usage)
}

func uniqueStrings(_ values: [String]) -> [String] {
    var seen = Set<String>()
    var result: [String] = []

    for value in values {
        if seen.insert(value).inserted {
            result.append(value)
        }
    }

    return result
}

func parseArguments(_ arguments: [String]) -> (outputDirectory: URL?, pretty: Bool) {
    var outputDirectory: URL?
    var pretty = false

    var index = 0
    while index < arguments.count {
        let argument = arguments[index]

        switch argument {
        case "--output-dir":
            index += 1
            guard index < arguments.count else {
                fail("missing value for --output-dir")
            }
            outputDirectory = URL(fileURLWithPath: arguments[index], isDirectory: true)
        case "--pretty":
            pretty = true
        case "-h", "--help":
            printUsage()
            exit(0)
        default:
            fail("unknown argument: \(argument)")
        }

        index += 1
    }

    return (outputDirectory, pretty)
}

func ensureOutputDirectory(_ requestedDirectory: URL?) throws -> URL {
    let fileManager = FileManager.default
    let directory = requestedDirectory ?? defaultOutputDirectory

    try fileManager.createDirectory(at: directory, withIntermediateDirectories: true)
    return directory
}

func clearExportedImages(in directory: URL) {
    let fileManager = FileManager.default
    let exportedNames = [
        "clipboard-image.png",
        "clipboard-image.jpg",
        "clipboard-image.tiff",
    ]

    for name in exportedNames {
        let fileURL = directory.appendingPathComponent(name)
        if fileManager.fileExists(atPath: fileURL.path) {
            try? fileManager.removeItem(at: fileURL)
        }
    }
}

func fileEntries(from urls: [URL]) -> [ClipboardFile] {
    var entries: [ClipboardFile] = []

    for url in urls {
        let values = try? url.resourceValues(forKeys: [.isDirectoryKey, .fileSizeKey])
        let isDirectory = values?.isDirectory ?? false
        let fileSize = values?.fileSize.map(Int64.init)

        entries.append(
            ClipboardFile(
                path: url.path,
                name: url.lastPathComponent,
                isDirectory: isDirectory,
                byteSize: isDirectory ? nil : fileSize
            )
        )
    }

    return entries
}

func exportImage(from pasteboard: NSPasteboard, requestedDirectory: URL?) throws -> (item: ClipboardItem, outputDirectory: URL)? {
    let pngType = NSPasteboard.PasteboardType.png
    let jpegType = NSPasteboard.PasteboardType("public.jpeg")
    let tiffType = NSPasteboard.PasteboardType.tiff

    if let pngData = pasteboard.data(forType: pngType) {
        let directory = try ensureOutputDirectory(requestedDirectory)
        clearExportedImages(in: directory)
        let fileURL = directory.appendingPathComponent("clipboard-image.png")
        try pngData.write(to: fileURL, options: .atomic)

        return (
            ClipboardItem(
                kind: "image",
                text: nil,
                length: nil,
                files: nil,
                urls: nil,
                path: fileURL.path,
                format: "png",
                sourceType: pngType.rawValue,
                byteSize: pngData.count
            ),
            directory
        )
    }

    if let jpegData = pasteboard.data(forType: jpegType) {
        let directory = try ensureOutputDirectory(requestedDirectory)
        clearExportedImages(in: directory)
        let fileURL = directory.appendingPathComponent("clipboard-image.jpg")
        try jpegData.write(to: fileURL, options: .atomic)

        return (
            ClipboardItem(
                kind: "image",
                text: nil,
                length: nil,
                files: nil,
                urls: nil,
                path: fileURL.path,
                format: "jpeg",
                sourceType: jpegType.rawValue,
                byteSize: jpegData.count
            ),
            directory
        )
    }

    if let tiffData = pasteboard.data(forType: tiffType) {
        let directory = try ensureOutputDirectory(requestedDirectory)
        clearExportedImages(in: directory)

        if let image = NSImage(data: tiffData),
           let imageTiffData = image.tiffRepresentation,
           let bitmap = NSBitmapImageRep(data: imageTiffData),
           let pngData = bitmap.representation(using: .png, properties: [:]) {
            let fileURL = directory.appendingPathComponent("clipboard-image.png")
            try pngData.write(to: fileURL, options: .atomic)

            return (
                ClipboardItem(
                    kind: "image",
                    text: nil,
                    length: nil,
                    files: nil,
                    urls: nil,
                    path: fileURL.path,
                    format: "png",
                    sourceType: tiffType.rawValue,
                    byteSize: pngData.count
                ),
                directory
            )
        }

        let fileURL = directory.appendingPathComponent("clipboard-image.tiff")
        try tiffData.write(to: fileURL, options: .atomic)

        return (
            ClipboardItem(
                kind: "image",
                text: nil,
                length: nil,
                files: nil,
                urls: nil,
                path: fileURL.path,
                format: "tiff",
                sourceType: tiffType.rawValue,
                byteSize: tiffData.count
            ),
            directory
        )
    }

    return nil
}

let parsed = parseArguments(Array(CommandLine.arguments.dropFirst()))
let pasteboard = NSPasteboard.general
let pasteboardTypes = pasteboard.types?.map(\.rawValue) ?? []

var items: [ClipboardItem] = []
var outputDirectory: URL?

let fileReadingOptions: [NSPasteboard.ReadingOptionKey: Any] = [
    .urlReadingFileURLsOnly: true,
]

let fileURLs = ((pasteboard.readObjects(forClasses: [NSURL.self], options: fileReadingOptions) as? [NSURL]) ?? [])
    .map { $0 as URL }

let uniqueFileURLs = uniqueStrings(fileURLs.map(\.path)).map { URL(fileURLWithPath: $0) }
if !uniqueFileURLs.isEmpty {
    items.append(
        ClipboardItem(
            kind: "files",
            text: nil,
            length: nil,
            files: fileEntries(from: uniqueFileURLs),
            urls: nil,
            path: nil,
            format: nil,
            sourceType: nil,
            byteSize: nil
        )
    )
}

let allURLs = ((pasteboard.readObjects(forClasses: [NSURL.self], options: nil) as? [NSURL]) ?? [])
    .map { $0 as URL }
let webURLs = uniqueStrings(allURLs.filter { !$0.isFileURL }.map(\.absoluteString))
if !webURLs.isEmpty {
    items.append(
        ClipboardItem(
            kind: "urls",
            text: nil,
            length: nil,
            files: nil,
            urls: webURLs,
            path: nil,
            format: nil,
            sourceType: nil,
            byteSize: nil
        )
    )
}

do {
    if let image = try exportImage(from: pasteboard, requestedDirectory: parsed.outputDirectory) {
        items.append(image.item)
        outputDirectory = image.outputDirectory
    }
} catch {
    fail(error.localizedDescription)
}

if let text = pasteboard.string(forType: .string), !text.isEmpty {
    items.append(
        ClipboardItem(
            kind: "text",
            text: text,
            length: text.count,
            files: nil,
            urls: nil,
            path: nil,
            format: "plain",
            sourceType: NSPasteboard.PasteboardType.string.rawValue,
            byteSize: nil
        )
    )
}

let dump = ClipboardDump(
    platform: "macOS",
    changeCount: pasteboard.changeCount,
    empty: items.isEmpty,
    pasteboardTypes: pasteboardTypes,
    outputDir: outputDirectory?.path,
    items: items
)

let encoder = JSONEncoder()
encoder.outputFormatting = parsed.pretty ? [.prettyPrinted, .sortedKeys] : [.sortedKeys]

do {
    let jsonData = try encoder.encode(dump)
    print(String(decoding: jsonData, as: UTF8.self))
} catch {
    fail(error.localizedDescription)
}
