#!/usr/bin/env bash

set -euo pipefail

fail() {
  echo "clip wrapper: $1" >&2
  exit 1
}

resolve_clip_binary() {
  local script_dir repo_root system arch target_dir binary_name clip_bin

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  repo_root="$(cd "$script_dir/.." && pwd)"
  system="$(uname -s)"
  arch="$(uname -m)"
  binary_name="clip"

  case "$system" in
    Darwin)
      case "$arch" in
        arm64|aarch64)
          target_dir="macos-aarch64"
          ;;
        *)
          fail "unsupported macOS architecture: $arch"
          ;;
      esac
      ;;
    Linux)
      case "$arch" in
        x86_64|amd64)
          target_dir="linux-x86_64-musl"
          ;;
        *)
          fail "unsupported Linux architecture: $arch"
          ;;
      esac
      ;;
    CYGWIN*|MINGW*|MSYS*)
      case "$arch" in
        x86_64|amd64)
          target_dir="windows-x86_64-gnu"
          binary_name="clip.exe"
          ;;
        *)
          fail "unsupported Windows architecture: $arch"
          ;;
      esac
      ;;
    *)
      fail "unsupported platform: $system"
      ;;
  esac

  clip_bin="$repo_root/clip/dist/$target_dir/$binary_name"
  if [[ ! -x "$clip_bin" ]]; then
    fail "missing clip binary: $clip_bin"
  fi

  printf '%s\n' "$clip_bin"
}

main() {
  local clip_bin

  clip_bin="$(resolve_clip_binary)"
  exec "$clip_bin" "$@"
}

main "$@"
